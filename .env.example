# 微信数据库原始路径（db_storage 目录）
WECHAT_DB_SRC_PATH=

# 微信安装路径
WECHAT_PATH=

# 数据库加密密钥（64 位十六进制，通过 extract_db_key 自动提取）
WECHAT_DB_KEY=

# 图片解密密钥
IMAGE_KEY=
XOR_KEY=

# 自己的 wxid（用于群聊中识别自己的消息）
SELF_WXID=

# 解密数据输出目录（默认 decrypted）
DATA_DIR=decrypted

# Python 路径（默认 python）
PYTHON_PATH=python

# Web 模式端口（默认 5200）
PORT=5200

# 自动刷新间隔毫秒（默认 60000，设为 0 禁用）
AUTO_REFRESH_MS=60000

# API 认证令牌（留空则不需要认证）
AUTH_TOKEN=

# AI 功能配置（可选）
AI_ENABLED=false
AI_API_URL=
AI_API_KEY=
AI_MODEL=
